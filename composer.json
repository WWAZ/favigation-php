{
    "name": "wwaz/favigation-php",
    "type": "library",
    "description": "Renders recursive navigation data",
    "keywords": ["navigation", "wordpress", "headless", "php"],
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "wwaz\\Favigation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "wwaz\\Favigation\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^10.5"
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --configuration=phpstan.neon",
        "lint": "phpstan analyse src --level=6"
    }
}
